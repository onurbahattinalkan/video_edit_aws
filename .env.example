# AWS Kimlik Bilgileri (yerel test için; production'da IAM Role kullanılması önerilir)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-central-1

# AWS Kinesis Video Streams
KVS_STREAM_NAME=demo-video-stream

# AWS Rekognition
REKOGNITION_MIN_CONFIDENCE=80
REKOGNITION_MAX_LABELS=10

# Veritabani (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/video_stream_db

# Uygulama
APP_ENV=development
APP_DEBUG=true
